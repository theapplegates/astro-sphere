// .eslintrc.json
{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "comma-dangle": ["error", "always-multiline"],
    "curly": ["error", "all"],
    "semi": ["error", "always"],
    "block-spacing": ["error", "always"],
    "brace-style": ["error", "1tbs"],
    "key-spacing": ["error", { "beforeColon": false, "afterColon": true }]
  }
}
